# Keep CI / scripts LF-only so a Windows checkout can't commit CRLF that breaks
# the GitHub Actions bash run-blocks (mixed-OS team).
*.yml   text eol=lf
*.yaml  text eol=lf
*.py    text eol=lf
*.sh    text eol=lf

# Generated map files — LF so local (Windows) and CI (Linux) output is byte-identical (no churn).
CODEMAP.md                  text eol=lf
frontend/public/codemap.html text eol=lf
